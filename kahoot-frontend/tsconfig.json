{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "@core/*": [
        "./src/app/core/*"
      ],
      "@env/*": [
        "./src/environments/*"
      ],
      "@ui-lib/*": [
        "./src/app/ui-lib/*"
      ],
      "@ui-lib/calendar": [
        "./src/app/ui-lib/calendar/src/index.ts"
      ],
      "@ui-lib/utils": [
        "./src/app/ui-lib/utils.ts"
      ],
      "@ui-lib/button": [
        "./src/app/ui-lib/button/src/index.ts"
      ],
      "@ui-lib/alert": [
        "./src/app/ui-lib/alert/src/index.ts"
      ],
      "@ui-lib/alert-dialog": [
        "./src/app/ui-lib/alert-dialog/src/index.ts"
      ],
      "@ui-lib/dropdown-menu": [
        "./src/app/ui-lib/dropdown-menu/src/index.ts"
      ],
      "@ui-lib/card": [
        "./src/app/ui-lib/card/src/index.ts"
      ],
      "@ui-lib/scroll-area": [
        "./src/app/ui-lib/scroll-area/src/index.ts"
      ],
      "@ui-lib/separator": [
        "./src/app/ui-lib/separator/src/index.ts"
      ],
      "@ui-lib/input": [
        "./src/app/ui-lib/input/src/index.ts"
      ],
      "@ui-lib/label": [
        "./src/app/ui-lib/label/src/index.ts"
      ],
      "@ui-lib/badge": [
        "./src/app/ui-lib/badge/src/index.ts"
      ],
      "@ui-lib/select": [
        "./src/app/ui-lib/select/src/index.ts"
      ],
      "@ui-lib/breadcrumb": [
        "./src/app/ui-lib/breadcrumb/src/index.ts"
      ],
      "@ui-lib/icon": [
        "./src/app/ui-lib/icon/src/index.ts"
      ],
      "@ui-lib/dialog": [
        "./src/app/ui-lib/dialog/src/index.ts"
      ],
      "@ui-lib/textarea": [
        "./src/app/ui-lib/textarea/src/index.ts"
      ],
      "@ui-lib/tooltip": [
        "./src/app/ui-lib/tooltip/src/index.ts"
      ],
      "@app-types": [
        "./src/app/types/types.ts"
      ],
      "@ui-lib/sidebar": [
        "./src/app/ui-lib/sidebar/src/index.ts"
      ],
      "@ui-lib/sheet": [
        "./src/app/ui-lib/sheet/src/index.ts"
      ],
      "@ui-lib/skeleton": [
        "./src/app/ui-lib/skeleton/src/index.ts"
      ]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
